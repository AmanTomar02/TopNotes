# Copy this file to backend/.env and fill in real values (backend/.env is gitignored).
# Run the backend container with:  docker run --env-file backend/.env ...
DB_HOST=topnotes-mysql
DB_PORT=3306
DB_NAME=topnotes_db
DB_USERNAME=root
DB_PASSWORD=root
FRONTEND_URL=http://localhost:4200,http://127.0.0.1:4200
FILE_UPLOAD_DIR=/app/uploads

# Cloudinary file storage — get these from your Cloudinary dashboard
# (console.cloudinary.com → "View API Keys"). Each dev can use their own account.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
